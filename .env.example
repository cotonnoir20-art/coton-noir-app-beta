# Copier vers `.env.local` (non versionné) pour le développement.
# Ne jamais committer de mots de passe réels.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Connexion rapide écran login (build dev uniquement, absent en release)
EXPO_PUBLIC_DEV_DEMO_EMAIL=
EXPO_PUBLIC_DEV_DEMO_PASSWORD=

# ── PWA beta (export web hébergé) ─────────────────────────────────────────────
# true = débloque l’app en build web (sinon écran « utilise l’app mobile »)
EXPO_PUBLIC_ALLOW_WEB_PROD=true
# true = session conservée au rechargement (sessionStorage, pas localStorage)
EXPO_PUBLIC_WEB_STAGING_AUTH_PERSIST=true
# URL Supabase → ajouter aussi dans Dashboard Auth → Redirect URLs (ton domaine HTTPS)

# Premium web beta (optionnel) :
# EXPO_PUBLIC_PREMIUM_CHECKOUT_URL=https://www.cotonnoir.app/premium

# Build : npm run build:web  → dossier dist/
# Vercel : voir scripts/vercel-env-checklist.txt + vercel.json (import Git ou CLI)
# Avant stores : retirer ALLOW_WEB_PROD ou le laisser false sur le build mobile uniquement
