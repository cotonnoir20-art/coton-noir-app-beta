{
  "expo": {
    "name": "Coton Noir",
    "slug": "coton-noir-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-dark.png",
    "description": "Ta copilote capillaire dans ton smartphone — diagnostic, routines, wash day, pousse en cm et communauté pour cheveux afro & texturés.",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cotonnoir.app",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.cotonnoir.app",
      "versionCode": 3,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/brand/splash-logo.png",
      "name": "Coton Noir",
      "shortName": "Coton Noir",
      "description": "Ton copilote capillaire — version beta web",
      "themeColor": "#7B0D14",
      "backgroundColor": "#FAF7F4",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "lang": "fr"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo-dark.png",
          "color": "#1A1A1A",
          "defaultChannel": "default"
        }
      ],
      "expo-iap",
      [
        "expo-camera",
        {
          "cameraPermission": "Coton Noir utilise la caméra pour scanner tes cheveux (racines, longueurs, pointes)."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f6c9b85-2272-4cb1-a811-b03d544f24ae"
      }
    },
    "owner": "flo-coton"
  }
}
